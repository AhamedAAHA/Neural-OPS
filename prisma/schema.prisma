generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["neural_ops"]
}

enum UserRole {
  admin
  analyst
  compliance_manager
  legal_counsel
  risk_officer
  executive
  @@schema("neural_ops")
}

enum IncidentStatus {
  open
  investigating
  pending_approval
  contained
  escalated
  resolved
  closed
  @@schema("neural_ops")
}

enum Severity {
  critical
  high
  medium
  low
  @@schema("neural_ops")
}

enum RoomStatus {
  active
  paused
  closed
  @@schema("neural_ops")
}

enum AgentStatus {
  idle
  active
  recruiting
  waiting
  completed
  offline
  @@schema("neural_ops")
}

enum AgentTier {
  Detection
  Investigation
  Intelligence
  Governance
  Response
  @@schema("neural_ops")
}

enum MessageType {
  CONTEXT_SHARE
  TASK_HANDOFF
  EVIDENCE_SUBMISSION
  REVIEW_REQUEST
  APPROVAL_REQUEST
  DECISION
  AGENT_RECRUITMENT
  RISK_UPDATE
  VOICE_COMMAND
  @@schema("neural_ops")
}

enum HandoffStatus {
  pending
  in_progress
  completed
  cancelled
  @@schema("neural_ops")
}

enum ApprovalStatus {
  pending
  approved
  rejected
  escalated
  @@schema("neural_ops")
}

enum ModelProvider {
  AIML_API
  FEATHERLESS
  OPENAI
  LOCAL
  @@schema("neural_ops")
}

enum ActorType {
  user
  agent
  system
  @@schema("neural_ops")
}

enum ObservabilitySource {
  API
  DATABASE
  AGENT
  BRIGHT_DATA
  BAND
  SPEECHMATICS
  REALTIME
  SYSTEM
  @@schema("neural_ops")
}

enum ObservabilityLevel {
  info
  warning
  error
  @@schema("neural_ops")
}

enum ServiceHealthStatus {
  healthy
  degraded
  down
  @@schema("neural_ops")
}

enum WorkflowTriggerType {
  NEW_INCIDENT
  VENDOR_RISK_THRESHOLD
  COMPLIANCE_VIOLATION
  NEW_DOCUMENT_UPLOAD
  @@schema("neural_ops")
}

enum WorkflowExecutionStatus {
  running
  completed
  failed
  @@schema("neural_ops")
}

enum DocumentType {
  pdf
  docx
  txt
  md
  html
  json
  other
  @@schema("neural_ops")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  country     String?
  industry    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users               User[]
  incidents           Incident[]
  documents           Document[]
  vendors             Vendor[]
  approvals           Approval[]
  bandRooms           BandRoom[]
  vendorIntelligence  VendorIntelligence[]
  auditLogs           AuditLog[]
  apiRequestMetrics   ApiRequestMetric[]
  monitoringEvents    MonitoringEvent[]
  serviceHealthChecks ServiceHealthCheck[]
  userActivities      UserActivity[]
  workflows           WorkflowDefinition[]
  workflowExecutions  WorkflowExecution[]
  boardReports        BoardIntelligenceReport[]
  @@schema("neural_ops")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      UserRole @default(analyst)
  authId    String?  @unique
  organizationId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incidentsCreated Incident[]       @relation("IncidentCreator")
  approvalsGiven   HumanApproval[]  @relation("ApprovalDecider")
  voiceCommands    VoiceCommand[]
  uploadedDocuments Document[]
  approvalsRequested Approval[]     @relation("ApprovalRequesterV2")
  approvalsDecided   Approval[]     @relation("ApprovalDeciderV2")
  workflowsCreated   WorkflowDefinition[]
  @@schema("neural_ops")
}

model Incident {
  id          String         @id @default(cuid())
  organizationId String?
  title       String
  description String         @db.Text
  type        String
  severity    Severity
  status      IncidentStatus @default(open)
  createdBy   String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  creator            User                @relation("IncidentCreator", fields: [createdBy], references: [id])
  rooms              InvestigationRoom[]
  evidence           Evidence[]
  riskAssessments    RiskAssessment[]
  complianceFindings ComplianceFinding[]
  legalFindings      LegalFinding[]
  approvals          HumanApproval[]
  reports            ExecutiveReport[]
  auditLogs          AuditLog[]
  voiceCommands      VoiceCommand[]
  modelInvocations   ModelInvocation[]
  documents          Document[]
  bandRooms          BandRoom[]
  approvalRecords    Approval[]
  vendorIntelligence VendorIntelligence[]
  apiRequestMetrics  ApiRequestMetric[]
  monitoringEvents   MonitoringEvent[]
  workflowExecutions WorkflowExecution[]
  boardReports       BoardIntelligenceReport[]
  @@schema("neural_ops")
}

model InvestigationRoom {
  id         String     @id @default(cuid())
  incidentId String
  bandRoomId String     @unique
  name       String
  status     RoomStatus @default(active)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  incident     Incident       @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  agents       Agent[]
  messages     AgentMessage[]
  handoffs     TaskHandoff[]
  @@schema("neural_ops")
}

model Agent {
  id         String      @id @default(cuid())
  name       String
  role       String
  tier       AgentTier
  framework  String      @default("band")
  provider   ModelProvider @default(AIML_API)
  status     AgentStatus @default(idle)
  capabilities Json      @default("[]")
  roomId     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  room                  InvestigationRoom? @relation(fields: [roomId], references: [id])
  messagesSent          AgentMessage[]     @relation("MessageSender")
  messagesReceived      AgentMessage[]     @relation("MessageRecipient")
  evidenceProduced      Evidence[]
  handoffsFrom          TaskHandoff[]      @relation("HandoffFrom")
  handoffsTo            TaskHandoff[]      @relation("HandoffTo")
  riskAssessments       RiskAssessment[]
  complianceFindings    ComplianceFinding[]
  legalFindings         LegalFinding[]
  approvalsRequested    HumanApproval[]
  voiceCommandsRouted   VoiceCommand[]
  modelInvocations      ModelInvocation[]
  @@schema("neural_ops")
}

model AgentMessage {
  id               String      @id @default(cuid())
  roomId           String
  agentId          String
  recipientAgentId String?
  messageType      MessageType
  contentJson      Json
  bandMessageId    String?     @unique
  modelProvider    ModelProvider?
  confidence       Float?
  createdAt        DateTime    @default(now())

  room      InvestigationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  agent     Agent             @relation("MessageSender", fields: [agentId], references: [id])
  recipient Agent?            @relation("MessageRecipient", fields: [recipientAgentId], references: [id])
  @@schema("neural_ops")
}

model Evidence {
  id              String   @id @default(cuid())
  incidentId      String
  sourceAgentId   String
  evidenceType    String
  title           String
  description     String   @db.Text
  confidence      Float
  metadataJson    Json     @default("{}")
  sourceReference String?
  bandMessageId   String?
  createdAt       DateTime @default(now())

  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sourceAgent Agent    @relation(fields: [sourceAgentId], references: [id])
  @@schema("neural_ops")
}

model TaskHandoff {
  id              String        @id @default(cuid())
  roomId          String
  fromAgentId     String
  toAgentId       String
  taskTitle       String
  taskPayloadJson Json          @default("{}")
  status          HandoffStatus @default(pending)
  bandMessageId   String?
  createdAt       DateTime      @default(now())
  completedAt     DateTime?

  room      InvestigationRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  fromAgent Agent             @relation("HandoffFrom", fields: [fromAgentId], references: [id])
  toAgent   Agent             @relation("HandoffTo", fields: [toAgentId], references: [id])
  @@schema("neural_ops")
}

model RiskAssessment {
  id                  String   @id @default(cuid())
  incidentId          String
  riskScore           Float
  financialImpact     Float
  legalImpact         Float
  reputationImpact    Float
  operationalImpact   Float
  customerImpact      Float
  recommendation      String   @db.Text
  generatedByAgentId  String
  createdAt           DateTime @default(now())

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  generatedByAgent Agent    @relation(fields: [generatedByAgentId], references: [id])
  @@schema("neural_ops")
}

model ComplianceFinding {
  id                 String   @id @default(cuid())
  incidentId         String
  regulation         String
  finding            String   @db.Text
  severity           Severity
  requiredAction     String   @db.Text
  generatedByAgentId String
  createdAt          DateTime @default(now())

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  generatedByAgent Agent    @relation(fields: [generatedByAgentId], references: [id])
  @@schema("neural_ops")
}

model LegalFinding {
  id                    String   @id @default(cuid())
  incidentId            String
  liability             String   @db.Text
  disclosureRequirement String   @db.Text
  legalExposure         Float
  recommendedAction     String   @db.Text
  generatedByAgentId    String
  createdAt             DateTime @default(now())

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  generatedByAgent Agent    @relation(fields: [generatedByAgentId], references: [id])
  @@schema("neural_ops")
}

model HumanApproval {
  id                  String         @id @default(cuid())
  incidentId          String
  requestedByAgentId  String
  actionTitle         String
  actionDescription   String         @db.Text
  riskLevel           Severity
  status              ApprovalStatus @default(pending)
  approvedBy          String?
  decisionNote        String?        @db.Text
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  incident         Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  requestedByAgent Agent    @relation(fields: [requestedByAgentId], references: [id])
  approver         User?    @relation("ApprovalDecider", fields: [approvedBy], references: [id])
  @@schema("neural_ops")
}

model ExecutiveReport {
  id                    String   @id @default(cuid())
  incidentId            String
  summary               String   @db.Text
  timelineJson          Json     @default("[]")
  evidenceJson          Json     @default("[]")
  riskJson              Json     @default("{}")
  complianceJson        Json     @default("[]")
  legalJson             Json     @default("[]")
  recommendationsJson   Json     @default("[]")
  agentContributionJson Json     @default("[]")
  approvalHistoryJson   Json     @default("[]")
  createdAt             DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  @@schema("neural_ops")
}

model AuditLog {
  id          String    @id @default(cuid())
  organizationId String?
  incidentId  String?
  actorType   ActorType
  actorId     String
  action      String
  detailsJson Json      @default("{}")
  createdAt   DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident?     @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  @@schema("neural_ops")
}

model VoiceCommand {
  id            String   @id @default(cuid())
  userId        String
  incidentId    String?
  audioUrl      String?
  transcript    String   @db.Text
  intent        String
  confidence    Float
  routedAgentId String?
  createdAt     DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  incident    Incident? @relation(fields: [incidentId], references: [id])
  routedAgent Agent?    @relation(fields: [routedAgentId], references: [id])
  @@schema("neural_ops")
}

model ModelInvocation {
  id               String        @id @default(cuid())
  provider         ModelProvider
  model            String
  agentId          String?
  incidentId       String?
  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  latencyMs        Int           @default(0)
  status           String        @default("success")
  createdAt        DateTime      @default(now())

  agent    Agent?    @relation(fields: [agentId], references: [id])
  incident Incident? @relation(fields: [incidentId], references: [id])
  @@schema("neural_ops")
}

model Document {
  id             String       @id @default(cuid())
  organizationId String?
  incidentId     String?
  uploadedBy     String
  name           String
  mimeType       String
  type           DocumentType @default(other)
  sizeBytes      Int
  storagePath    String
  publicUrl      String?
  textContent    String?      @db.Text
  metadataJson   Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident?      @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  uploader     User           @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)
  chunks       DocumentChunk[]

  @@index([incidentId])
  @@index([organizationId])
  @@schema("neural_ops")
}

model DocumentChunk {
  id            String   @id @default(cuid())
  documentId    String
  chunkIndex    Int
  content       String   @db.Text
  tokenCount    Int      @default(0)
  embeddingJson Json     @default("[]")
  createdAt     DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@schema("neural_ops")
}

model BandRoom {
  id             String    @id @default(cuid())
  organizationId String?
  incidentId     String
  roomExternalId String?   @unique
  name           String
  status         String    @default("active")
  connectedAgents Int      @default(0)
  messageCount    Int      @default(0)
  lastActivityAt  DateTime?
  metadataJson   Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@schema("neural_ops")
}

model Vendor {
  id             String   @id @default(cuid())
  organizationId String?
  name           String
  country        String?
  industry       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  intelligence  VendorIntelligence[]

  @@unique([organizationId, name])
  @@index([name])
  @@schema("neural_ops")
}

model VendorIntelligence {
  id             String   @id @default(cuid())
  organizationId String?
  vendorId       String
  incidentId     String?
  source         String
  findingsJson   Json     @default("{}")
  riskScore      Int
  summary        String?  @db.Text
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  vendor       Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  incident     Incident?     @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([incidentId])
  @@schema("neural_ops")
}

model Approval {
  id             String         @id @default(cuid())
  organizationId String?
  incidentId     String
  chainId        String?
  chainOrder     Int?
  approverRole   String?
  approverName   String?
  requestedById  String?
  decidedById    String?
  title          String
  description    String         @db.Text
  riskLevel      Severity
  status         ApprovalStatus @default(pending)
  decisionNote   String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  requestedBy  User?         @relation("ApprovalRequesterV2", fields: [requestedById], references: [id], onDelete: SetNull)
  decidedBy    User?         @relation("ApprovalDeciderV2", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([incidentId])
  @@index([organizationId])
  @@index([chainId])
  @@schema("neural_ops")
}

model ApiRequestMetric {
  id             String   @id @default(cuid())
  organizationId String?
  incidentId     String?
  userId         String?
  route          String
  method         String
  statusCode     Int
  durationMs     Int
  errorMessage   String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident?     @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([route, createdAt])
  @@schema("neural_ops")
}

model MonitoringEvent {
  id             String              @id @default(cuid())
  organizationId String?
  incidentId     String?
  source         ObservabilitySource
  level          ObservabilityLevel  @default(info)
  operation      String
  status         String              @default("ok")
  durationMs     Int?
  message        String?
  detailsJson    Json                @default("{}")
  createdAt      DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  incident     Incident?     @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([source, createdAt])
  @@schema("neural_ops")
}

model ServiceHealthCheck {
  id                String              @id @default(cuid())
  organizationId    String?
  service           String
  status            ServiceHealthStatus @default(healthy)
  responseTimeMs    Int?
  errorRatePct      Float?
  activeConnections Int?
  activeUsers       Int?
  detailsJson       Json                @default("{}")
  createdAt         DateTime            @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, service, createdAt])
  @@schema("neural_ops")
}

model UserActivity {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String
  path           String?
  lastSeenAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([organizationId, lastSeenAt])
  @@schema("neural_ops")
}

model WorkflowDefinition {
  id                String              @id @default(cuid())
  organizationId    String
  createdById       String?
  name              String
  description       String?             @db.Text
  triggerType       WorkflowTriggerType
  triggerConfigJson Json                @default("{}")
  actionsJson       Json                @default("[]")
  graphJson         Json                @default("{}")
  enabled           Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  executions   WorkflowExecution[]

  @@index([organizationId, enabled, triggerType])
  @@schema("neural_ops")
}

model WorkflowExecution {
  id                String                  @id @default(cuid())
  workflowId        String
  organizationId    String
  incidentId        String?
  status            WorkflowExecutionStatus @default(running)
  triggerPayloadJson Json                   @default("{}")
  actionResultsJson  Json                   @default("[]")
  errorMessage      String?                 @db.Text
  startedAt         DateTime                @default(now())
  completedAt       DateTime?

  workflow     WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     Incident?          @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([organizationId, startedAt])
  @@index([workflowId, startedAt])
  @@schema("neural_ops")
}

model BoardIntelligenceReport {
  id                  String   @id @default(cuid())
  organizationId      String
  incidentId          String?
  generatedBy         String   @default("enterprise_forecast_agent")
  summary             String   @db.Text
  outlook30Json       Json     @default("{}")
  outlook90Json       Json     @default("{}")
  outlook180Json      Json     @default("{}")
  vendorTrendJson     Json     @default("{}")
  recommendationsJson Json     @default("[]")
  generatedAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incident     Incident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([organizationId, generatedAt])
  @@index([incidentId, generatedAt])
  @@schema("neural_ops")
}
