# Core
NODE_ENV=production
PORT=3000

# Database (Supabase PostgreSQL)
# Pooled connection for the app (port 6543 with pgbouncer=true)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&schema=neural_ops"
# Direct/session connection for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?schema=neural_ops"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Band SDK / Band Agent API
BAND_API_KEY=""
BAND_WORKSPACE_ID=""
BAND_AGENT_SECRET=""
BAND_API_BASE_URL="https://api.band.ai/v1"
USE_MOCK_BAND=false

# AIML API (OpenAI-compatible)
AIML_API_KEY=""
AIML_BASE_URL="https://api.aimlapi.com/v1"
AIML_MODEL="gpt-4o-mini"

# Featherless API (OpenAI-compatible)
FEATHERLESS_API_KEY=""
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"
FEATHERLESS_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# OpenAI fallback (optional)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Bright Data
BRIGHT_DATA_API_KEY=""
BRIGHT_DATA_BASE_URL="https://api.brightdata.com"
BRIGHT_DATA_SERP_ZONE=""
BRIGHT_DATA_WEB_UNLOCKER_ZONE=""
USE_MOCK_BRIGHT_DATA=false

# Speechmatics
SPEECHMATICS_API_KEY=""
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_TTS_VOICE=sarah
USE_MOCK_SPEECHMATICS=false

# Auth
AUTH_DEV_MODE=false
AUTH_LOGIN_RATE_LIMIT=500
AUTH_LOGIN_RATE_WINDOW_MS=3600000
AUTH_REGISTER_RATE_LIMIT=500
AUTH_REGISTER_RATE_WINDOW_MS=3600000

# App
NEXT_PUBLIC_APP_NAME="Neural OPS"
NEXT_PUBLIC_APP_TAGLINE="Where AI agents investigate, reason, collaborate, and execute enterprise decisions."

# Observability
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_TRACES_SAMPLE_RATE=0.2
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_CONSOLE_EXPORTER=false
OTEL_DISABLED=false
OBSERVE_DB_QUERIES=true

# Production validation (enforces required env + live integrations when mocks are off)
ENV_VALIDATION_STRICT=true
