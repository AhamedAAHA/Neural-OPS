# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Band SDK / Band Agent API
BAND_API_KEY=""
BAND_WORKSPACE_ID=""
BAND_AGENT_SECRET=""
BAND_API_BASE_URL="https://api.band.ai/v1"
USE_MOCK_BAND=true

# AIML API (OpenAI-compatible)
AIML_API_KEY=""
AIML_BASE_URL="https://api.aimlapi.com/v1"
AIML_MODEL="gpt-4o-mini"

# Featherless API (OpenAI-compatible)
FEATHERLESS_API_KEY=""
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"
FEATHERLESS_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# Speechmatics
SPEECHMATICS_API_KEY=""
SPEECHMATICS_LANGUAGE=en

# OpenAI fallback
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Auth (dev mode uses headers when unset)
AUTH_DEV_MODE=true
DEV_USER_ID=""
DEV_USER_ROLE=analyst
DEMO_LOGIN_EMAIL="admin@neural-ops.ai"
DEMO_LOGIN_PASSWORD=""
DEMO_LOGIN_CODE=""

# App
NEXT_PUBLIC_APP_NAME="Neural OPS"
