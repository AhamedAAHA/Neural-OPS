{
  "name": "neural-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate --no-engine && next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint src prisma --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --no-engine",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "admin:ensure": "tsx scripts/ensure-admin-user.ts",
    "db:studio": "prisma studio",
    "preview": "prisma generate --no-engine && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "prisma generate --no-engine && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "prisma generate --no-engine && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@react-three/drei": "^10.0.6",
    "@react-three/fiber": "^9.1.2",
    "@sentry/nextjs": "^10.57.0",
    "@sentry/node": "^10.57.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tanstack/react-query": "^5.80.7",
    "@xyflow/react": "^12.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.9.2",
    "gsap": "^3.13.0",
    "lucide-react": "^0.511.0",
    "mammoth": "^1.12.0",
    "next": "^15.3.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.0",
    "three": "^0.176.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.176.0",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.100.0"
  }
}
