# Neural OPS Production Environment Configuration
# Copy this to Vercel Environment Variables with sensitive values filled in

# ============================================================================
# CORE APPLICATION
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================================
# Pooled connection for app queries (pgbouncer=true, port 6543)
DATABASE_URL="postgresql://postgres.lpbkkrzutagrisvpapwy:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=neural_ops"

# Direct/session connection for migrations (port 5432)
DIRECT_URL="postgresql://postgres.lpbkkrzutagrisvpapwy:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?schema=neural_ops"

# ============================================================================
# SUPABASE AUTHENTICATION
# ============================================================================
# Public-facing Supabase configuration (safe in code/git)
NEXT_PUBLIC_SUPABASE_URL="https://lpbkkrzutagrisvpapwy.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_acSVaw0zijlxGbqqqXFfeA_CgmzvxZN"

# Server-side only - NEVER expose to client
# Store this securely in Vercel environment variables only
SUPABASE_SERVICE_ROLE_KEY="[ROTATE_AND_SET_IN_VERCEL]"

# ============================================================================
# AUTHENTICATION SETTINGS
# ============================================================================
AUTH_DEV_MODE=false

# ============================================================================
# BAND SDK / BAND AGENT API
# ============================================================================
BAND_API_KEY="[SET_IN_VERCEL]"
BAND_WORKSPACE_ID="[SET_IN_VERCEL]"
BAND_AGENT_SECRET="[SET_IN_VERCEL]"
BAND_API_BASE_URL="https://api.band.ai/v1"
USE_MOCK_BAND=false

# ============================================================================
# AIML API (OpenAI-compatible)
# ============================================================================
AIML_API_KEY="[SET_IN_VERCEL]"
AIML_BASE_URL="https://api.aimlapi.com/v1"
AIML_MODEL="gpt-4o-mini"

# ============================================================================
# FEATHERLESS API (OpenAI-compatible)
# ============================================================================
FEATHERLESS_API_KEY="[SET_IN_VERCEL]"
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"
FEATHERLESS_MODEL="meta-llama/Llama-3.3-70B-Instruct"

# ============================================================================
# OPENAI FALLBACK (optional)
# ============================================================================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ============================================================================
# BRIGHT DATA
# ============================================================================
BRIGHT_DATA_API_KEY="[SET_IN_VERCEL]"
BRIGHT_DATA_BASE_URL="https://api.brightdata.com"
BRIGHT_DATA_SERP_ZONE="[SET_IN_VERCEL]"
BRIGHT_DATA_WEB_UNLOCKER_ZONE="[SET_IN_VERCEL]"
USE_MOCK_BRIGHT_DATA=false

# ============================================================================
# SPEECHMATICS
# ============================================================================
SPEECHMATICS_API_KEY="[SET_IN_VERCEL]"
SPEECHMATICS_LANGUAGE=en
SPEECHMATICS_TTS_VOICE=sarah
USE_MOCK_SPEECHMATICS=false

# ============================================================================
# APPLICATION BRANDING
# ============================================================================
NEXT_PUBLIC_APP_NAME="Neural OPS"
NEXT_PUBLIC_APP_TAGLINE="Where AI agents investigate, reason, collaborate, and execute enterprise decisions."

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================
# Sentry Error Tracking (optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_TRACES_SAMPLE_RATE=0.2

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_EXPORTER_OTLP_HEADERS=""
OTEL_CONSOLE_EXPORTER=false
OTEL_DISABLED=false

# Query Observability
OBSERVE_DB_QUERIES=true

# ============================================================================
# PRODUCTION VALIDATION
# ============================================================================
# Enforces all required environment variables and validates live integrations
ENV_VALIDATION_STRICT=true

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file content to Vercel Settings → Environment Variables
#
# 2. For each [SET_IN_VERCEL] value, enter the actual secret:
#    - SUPABASE_SERVICE_ROLE_KEY: Rotate via Supabase Dashboard
#    - BAND_API_KEY: From Band dashboard
#    - AIML_API_KEY: From AIML provider
#    - FEATHERLESS_API_KEY: From Featherless provider
#    - OPENAI_API_KEY: From OpenAI (optional)
#    - BRIGHT_DATA_API_KEY: From Bright Data account
#    - SPEECHMATICS_API_KEY: From Speechmatics account
#
# 3. For DATABASE_URL and DIRECT_URL, replace [PASSWORD] with:
#    - Go to Supabase Dashboard → Settings → Database
#    - Copy the connection string and replace the [PASSWORD] placeholder
#
# 4. Deploy to production:
#    vercel deploy --prod
#
# 5. Verify deployment:
#    - Check build logs for environment variable errors
#    - Test application endpoints
#    - Monitor Sentry for errors
#
# ============================================================================
